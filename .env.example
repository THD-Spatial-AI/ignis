# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=ignis
DB_SSL_MODE=disable

# CORS — comma-separated list of origins allowed to call this API.
# In production set this to the exact frontend URL (no trailing slash).
# Example: ALLOWED_ORIGINS=https://app.example.com
# For local development the defaults below cover Vite (5173) and CRA/Next (3000).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000