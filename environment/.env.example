# Read by the `docker compose` CLI for ${VARIABLE} substitution inside
# docker-compose.yml. NOT injected into any container — that's docker.env's job.
#
# Copy to `.env` in this directory and adjust for your machine:
#   cp .env.example .env

# Host path to Caddy's local CA storage, so the containerized Caddy reuses
# the same locally-trusted CA instead of generating a new (untrusted) one.
# Run `caddy trust` on the host first (requires Caddy installed locally), then
# point this at wherever that created the CA — typically:
#   Linux:   ~/.local/share/caddy
#   macOS:   ~/Library/Application Support/Caddy
CADDY_DATA_DIR=/home/YOUR_USERNAME/.local/share/caddy

# The host port the reverse proxy publishes. This is the one port that can
# collide when several services (ignis, buem, …) run side by side, since only
# one process may own a given host port. An orchestration layer assigns a free
# port here per service; 443 is the local-dev default.
HOST_HTTPS_PORT=443

# The internal port the app listens on, inside its own container. Container
# network-namespace isolation means this never collides across services, so it
# can stay the same everywhere — it is a single source of truth referenced by
# the app, its health check, and the reverse proxy's upstream, not a value
# duplicated in each of those places.
APP_PORT=8080
