# Server Configuration
APP_PORT=8080

# Host port mapping (host port -> container APP_PORT)
# Change HOST_PORT if 8080 collides with another service on your machine.
HOST_PORT=8080

# Database connection settings (connects to host PostgreSQL)
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ignis
DB_SSL_MODE=disable  # use "require" in production

# CORS — origins allowed to call this API from a browser.
# Comma-separated. Must match the exact origin (no trailing slash).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
