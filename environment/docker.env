# NOTE: APP_PORT (the app's internal listen port) and HOST_HTTPS_PORT (the
# reverse proxy's published port) live in `.env`, not here — they are consumed
# by docker-compose.yml's ${...} interpolation and passed into the containers
# from there, so the app, its health check, and the proxy all share one value.

# Database connection settings (connects to the database container on the
# same Docker Compose network, via its service name)
DB_HOST=ignis-db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ignis
DB_SSL_MODE=disable  # use "require" in production

# Consumed by the official postgres image's own entrypoint (different
# variable names than ignis's DB_* above; same values, kept in sync manually).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ignis

# CORS — origins allowed to call this API from a browser. Comma-separated,
# must match the exact origin (no trailing slash). Single source for BOTH
# consumers: ignis-app's own Go CORS middleware reads this directly, and
# ignis-reverse-proxy derives a regex from it at startup for its preflight
# matcher (see docker-compose.yml + Caddyfile). Add an origin here once —
# nothing to update in the Caddyfile itself.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000,https://thd-spatial-ai.github.io

# Read by ignis-reverse-proxy's Caddyfile to gate the app behind the
# X-Api-Key header. Callers must send this same value. Rotate before any
# real deployment — this is a local-dev placeholder, not a secret.
IGNIS_API_KEY=supersecret123
